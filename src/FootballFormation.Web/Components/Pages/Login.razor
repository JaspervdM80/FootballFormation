@page "/login"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject NavigationManager Navigation
@inject IStringLocalizer<FootballFormation.UI.Strings> L
@attribute [AllowAnonymous]

<PageTitle>@L["Login"]</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: calc(100vh - 120px);">
    <div style="width: 100%; max-width: 380px; background: var(--gradient-card); border: 1px solid color-mix(in srgb, var(--ink) 8%, transparent); border-radius: 16px; padding: 40px; box-shadow: 0 8px 32px rgba(0,0,0,0.08);">
        <div style="text-align: center; margin-bottom: 32px;">
            <span style="font-size: 2rem;">&#9917;</span>
            <h2 style="color: var(--ink); font-weight: 700; margin: 8px 0 4px;">@L["Admin Login"]</h2>
            <p style="color: color-mix(in srgb, var(--ink) 50%, transparent); font-size: 0.875rem;">@L["Sign in to manage formations"]</p>
        </div>

        @if (_showError)
        {
            <div style="background: color-mix(in srgb, var(--color-danger) 12%, transparent); border: 1px solid color-mix(in srgb, var(--color-danger) 30%, transparent); border-radius: 8px; padding: 12px; margin-bottom: 20px; color: var(--color-danger-bright); font-size: 0.875rem; text-align: center;">
                @L["Invalid username or password"]
            </div>
        }

        <form method="post" action="/auth/login" data-enhance="false">
            <input type="hidden" name="returnUrl" value="@_returnUrl" />

            <div style="margin-bottom: 16px;">
                <label style="display: block; color: color-mix(in srgb, var(--ink) 60%, transparent); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">@L["Username"]</label>
                <input type="text" name="username" required autocomplete="username" autofocus
                       style="width: 100%; padding: 10px 14px; background: var(--surface-page); border: 1px solid color-mix(in srgb, var(--ink) 15%, transparent); border-radius: 8px; color: var(--ink); font-size: 0.95rem; outline: none; box-sizing: border-box;" />
            </div>

            <div style="margin-bottom: 24px;">
                <label style="display: block; color: color-mix(in srgb, var(--ink) 60%, transparent); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">@L["Password"]</label>
                <input type="password" name="password" required autocomplete="current-password"
                       style="width: 100%; padding: 10px 14px; background: var(--surface-page); border: 1px solid color-mix(in srgb, var(--ink) 15%, transparent); border-radius: 8px; color: var(--ink); font-size: 0.95rem; outline: none; box-sizing: border-box;" />
            </div>

            <button type="submit"
                    style="width: 100%; padding: 12px; background: var(--gradient-primary); border: none; border-radius: 8px; color: var(--club-on-primary); font-weight: 700; font-size: 0.95rem; cursor: pointer;">
                @L["Sign In"]
            </button>
        </form>

        <div style="text-align: center; margin-top: 20px;">
            <a href="/" style="color: color-mix(in srgb, var(--ink) 45%, transparent); font-size: 0.8rem; text-decoration: none;">@L["Continue as viewer"]</a>
        </div>
    </div>
</div>

@code {
    private bool _showError;
    private string _returnUrl = "";

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        _showError = query.ContainsKey("error");
        if (query.TryGetValue("returnUrl", out var returnUrl))
            _returnUrl = returnUrl.ToString();
    }
}
