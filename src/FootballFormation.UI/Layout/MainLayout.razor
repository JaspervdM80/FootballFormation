@inherits LayoutComponentBase
@inject IStringLocalizer<Strings> L

<MudThemeProvider Theme="Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Dense="true" Style="background: linear-gradient(to right, #13131f, #1a1a2e); border-bottom: 1px solid rgba(255,255,255,0.05); padding-top: env(safe-area-inset-top, 0px);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Class="nav-hamburger" Edge="Edge.Start"
                       Style="color: rgba(255,255,255,0.7);" OnClick="ToggleDrawer" aria-label="Menu" />
        <a href="/" class="app-title-link ml-2 mr-8" aria-label="@L["Start"]">
            <img src="icons/icon-192.png" alt="" class="app-title-logo" />
            <span class="app-title-text">GJS Meiden</span>
        </a>
        <div class="d-flex gap-1 topbar-nav">
            <MudNavLink Href="/" Match="NavLinkMatch.All"
                        Class="topbar-nav-link">@L["Start"]</MudNavLink>
            <MudNavLink Href="/players" Match="NavLinkMatch.Prefix"
                        Class="topbar-nav-link">@L["Squad"]</MudNavLink>
            <MudNavLink Href="/games" Match="NavLinkMatch.Prefix"
                        Class="topbar-nav-link">@L["Games"]</MudNavLink>
            <AuthorizeView>
                <MudNavLink Href="/settings" Match="NavLinkMatch.All"
                            Class="topbar-nav-link">@L["Preferences"]</MudNavLink>
            </AuthorizeView>
        </div>
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.Language" Size="Size.Small" Dense="true"
                 AriaLabel="Language" Style="color: rgba(255,255,255,0.4);">
            <MudMenuItem OnClick="@(() => SwitchCulture("nl"))">Nederlands</MudMenuItem>
            <MudMenuItem OnClick="@(() => SwitchCulture("en"))">English</MudMenuItem>
        </MudMenu>
        <AuthorizeView>
            <Authorized>
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" Style="color: #fbbf24;" />
                    <MudText Typo="Typo.body2" Class="admin-name" Style="color: rgba(255,255,255,0.5);">@context.User.Identity?.Name</MudText>
                    <form method="post" action="/auth/logout" data-enhance="false" style="margin: 0;">
                        <button type="submit"
                                style="background: none; border: none; color: rgba(255,255,255,0.3); cursor: pointer; font-size: 0.875rem; padding: 4px 8px; text-transform: none;">
                            @L["Logout"]
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Target="_self" Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Lock"
                           Style="color: rgba(255,255,255,0.3); text-transform: none;">
                    Admin
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="@DrawerVariant.Temporary" Elevation="2"
               Style="padding-top: env(safe-area-inset-top, 0px);">
        <a href="/" class="app-title-link pa-4">
            <img src="icons/icon-192.png" alt="" class="app-title-logo" />
            <span class="app-title-text">GJS Meiden</span>
        </a>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">@L["Start"]</MudNavLink>
            <MudNavLink Href="/players" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Groups">@L["Squad"]</MudNavLink>
            <MudNavLink Href="/games" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.SportsSoccer">@L["Games"]</MudNavLink>
            <AuthorizeView>
                <MudNavLink Href="/settings" Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Filled.Settings">@L["Preferences"]</MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Style="padding: calc(76px + env(safe-area-inset-top, 0px)) 24px calc(40px + env(safe-area-inset-bottom, 0px)); max-width: 1100px; margin: 0 auto;">
        @Body
    </MudMainContent>

    <InstallBanner />
</MudLayout>
