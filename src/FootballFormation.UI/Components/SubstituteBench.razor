<MudPaper Class="pa-3" Elevation="2"
          @ondragover:preventDefault="true"
          @ondrop="() => OnPlayerDroppedToSub.InvokeAsync()">
    <MudText Typo="Typo.subtitle2" GutterBottom="true">Substitutes</MudText>

    @if (DraggedPlayerId is not null)
    {
        <div class="sub-drop-zone">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" />
            <MudText Typo="Typo.caption">Drop here to add as sub</MudText>
        </div>
    }

    @{
        var subs = Lineup.Where(p => p.IsSubstitute).ToList();
    }

    @if (subs.Count > 0)
    {
        <div class="sub-list">
            @foreach (var sub in subs)
            {
                <div class="sub-item d-flex align-center justify-space-between"
                     draggable="true"
                     @ondragstart="() => OnSubDragStart.InvokeAsync(sub.PlayerId)"
                     @ondragstart:stopPropagation="true"
                     @ondragover:preventDefault="true"
                     @ondrop="() => OnSwapWithSub.InvokeAsync(sub.PlayerId)"
                     @ondrop:stopPropagation="true"
                     style="cursor: grab; padding: 4px 8px;">
                    <div>
                        <MudText Typo="Typo.body2">
                            @(sub.Player?.ShirtNumber.HasValue == true ? $"#{sub.Player.ShirtNumber} " : "")@sub.Player?.DisplayName
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @sub.Position.ToString()
                        </MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   OnClick="() => OnSubRemoved.InvokeAsync(sub)" />
                </div>
            }
        </div>
    }
    else if (DraggedPlayerId is null)
    {
        <MudText Typo="Typo.caption" Color="Color.Tertiary">Drag players here to add as subs</MudText>
    }
</MudPaper>
