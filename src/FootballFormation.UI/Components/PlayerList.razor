<MudPaper Class="pa-2" Elevation="2" Style="max-height: 70vh; overflow-y: auto;">
    <MudText Typo="Typo.subtitle2" Class="mb-2">Available Players</MudText>

    @if (Players.Count == 0)
    {
        <MudText Typo="Typo.caption" Color="Color.Tertiary">All players assigned</MudText>
    }

    @foreach (var player in Players)
    {
        <div class="draggable-player"
             draggable="true"
             @ondragstart="() => OnDragStart.InvokeAsync(player.Id)">
            <span class="player-shirt">@(player.ShirtNumber?.ToString() ?? "-")</span>
            <div class="player-info">
                <span class="player-name-text">@player.DisplayName</span>
                <span class="player-pos-text">@player.PreferredPosition.ToString()</span>
            </div>
        </div>
    }
</MudPaper>
