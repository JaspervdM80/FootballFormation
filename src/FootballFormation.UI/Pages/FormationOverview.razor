@page "/games/{GameId:int}/overview"
@inject IStringLocalizer<Strings> L

<PageTitle>@L["Formation Overview"]</PageTitle>

@if (GameData is null)
{
    <MudProgressCircular Indeterminate="true" />
    return;
}

<div class="overview-capture" id="formation-overview">
    <div class="overview-header">
        <div class="overview-header-left">
            <span class="overview-title">@(GameData.IsHomeGame ? "vs" : "@") @GameData.Opponent</span>
            <span class="overview-date">@GameData.Date.ToString("dd MMM yyyy") · @(GameData.IsHomeGame ? L["Home"] : L["Away"])</span>
            <span class="overview-formation">@GameData.FormationType.DisplayName()</span>
        </div>
    </div>

    <div class="overview-periods">
        @foreach (var period in GameData.Periods.OrderBy(p => p.PeriodType))
        {
            var formation = period.FormationTypeOverride ?? GameData.FormationType;
            var lineup = PeriodLineups.GetValueOrDefault(period.Id, []);
            var starters = lineup.Where(p => !p.IsSubstitute).ToList();
            var subs = lineup.Where(p => p.IsSubstitute).ToList();

            <div class="overview-period-card">
                <div class="period-label">@L[period.PeriodType.DisplayName()]</div>
                <PitchOverview Formation="formation" Positions="starters" HidePositionFit="IsAnonymous" />
                @if (subs.Count > 0)
                {
                    <div class="subs-row">
                        <span class="subs-label">@L["Subs"]:</span>
                        @foreach (var sub in subs)
                        {
                            <span class="sub-badge">
                                @if (sub.Player?.ShirtNumber is not null)
                                {
                                    <span class="sub-number">#@sub.Player.ShirtNumber</span>
                                }
                                @(sub.Player?.ShortName ?? L["Player {0}", sub.PlayerId].Value)
                            </span>
                        }
                    </div>
                }
                else
                {
                    <div class="subs-row">
                        <span class="subs-label subs-none">@L["No subs"]</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="overview-actions">
    <AuthorizeView>
        <Authorized>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="btn-ghost"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="NavigateToEditor">
                @L["Back to editor"]
            </MudButton>
        </Authorized>
        <NotAuthorized>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="btn-ghost"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="NavigateToGames">
                @L["Back to games"]
            </MudButton>
        </NotAuthorized>
    </AuthorizeView>
    <MudButton Variant="Variant.Filled" Size="Size.Small" Class="btn-gold"
               StartIcon="@Icons.Material.Filled.CameraAlt"
               OnClick="CaptureScreenshot">
        @L["Save as image"]
    </MudButton>
</div>
