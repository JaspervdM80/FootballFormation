@page "/games/{GameId:int}/formation"
@attribute [Authorize]

<PageTitle>@L["Formation Builder"]</PageTitle>

@if (GameData is null || AllPlayers is null)
{
    <MudProgressCircular Indeterminate="true" />
    return;
}

<div class="builder-header mb-3">
    <div class="builder-header-top">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack" Size="Size.Small"
                       Style="color: color-mix(in srgb, var(--ink) 40%, transparent);" />
        <MudText Typo="Typo.h6" Class="builder-opponent"
                 Style="color: var(--ink); font-weight: 700; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            @(GameData.IsHomeGame ? "vs" : "@") @GameData.Opponent
        </MudText>
    </div>
    <div class="builder-meta">
        <span class="badge-venue">@((GameData.IsHomeGame ? L["Home"] : L["Away"]).ToString().ToUpper())</span>
        <span class="builder-date">@GameData.Date.ToString("dd MMM yyyy")</span>
        <span class="badge-gold">@GameData.FormationType.DisplayName()</span>
    </div>
</div>

@{
    var orderedPeriods = GameData.Periods.OrderBy(p => p.PeriodType).ToList();
    var activeIndex = Math.Clamp(ActivePeriodIndex, 0, orderedPeriods.Count - 1);
    var activePeriod = orderedPeriods[activeIndex];
    var periodFormation = activePeriod.FormationTypeOverride ?? GameData.FormationType;
}

<div class="d-flex justify-end mb-2">
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Share" Class="btn-ghost"
               Href="@($"/games/{GameId}/overview")">
        @L["Overview"]
    </MudButton>
</div>

<MudSelect T="int" @bind-Value="ActivePeriodIndex" Dense="true" Variant="Variant.Outlined"
           Label="@L[GameData.SplitType.PeriodLabel()]" Class="period-select mb-3">
    @for (var i = 0; i < orderedPeriods.Count; i++)
    {
        var index = i;
        var period = orderedPeriods[i];
        <MudSelectItem Value="@index">@L[period.PeriodType.DisplayName()]</MudSelectItem>
    }
</MudSelect>

<div class="formation-layout mt-2">
    <div class="player-list-panel">
        <PlayerList Players="GetAvailablePlayers(activePeriod.Id)"
                    OnDragStart="OnPlayerDragStart" />
        @if (UnavailablePlayers.Count > 0)
        {
            <MudPaper Class="pa-2 mt-2" Elevation="1" Style="opacity: 0.6; border-radius: 10px;">
                <MudText Typo="Typo.subtitle2" Class="mb-1" Style="color: var(--color-danger-bright);">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small" Class="mr-1" />
                    @L["Unavailable"] (@UnavailablePlayers.Count)
                </MudText>
                @foreach (var player in UnavailablePlayers)
                {
                    <div class="unavailable-player">
                        <span class="player-shirt unavailable">@(player.ShirtNumber?.ToString() ?? "-")</span>
                        <span class="player-name-text">@player.DisplayName</span>
                    </div>
                }
            </MudPaper>
        }
    </div>
    <div class="pitch-panel">
        <PitchView Formation="periodFormation"
                   Positions="PeriodLineups[activePeriod.Id]"
                   DraggedPlayerId="Drag.PlayerId"
                   OnPlayerDropped="(slot) => OnPlayerDropped(activePeriod.Id, slot)"
                   OnPlayerRemoved="(slot) => OnPlayerRemoved(activePeriod.Id, slot)"
                   OnPlayerDragStart="(slot) => OnPitchPlayerDragStart(activePeriod.Id, slot)" />
        <div class="pitch-legend">
            <span class="legend-item"><span class="legend-dot chip-preferred"></span> @L["Exact"]</span>
            <span class="legend-item"><span class="legend-dot chip-natural"></span> @L["Natural fit"]</span>
            <span class="legend-item"><span class="legend-dot chip-alternative"></span> @L["Alternative"]</span>
            <span class="legend-item"><span class="legend-dot chip-compatible"></span> @L["Compatible"]</span>
            <span class="legend-item"><span class="legend-dot chip-out-of-position"></span> @L["Out of position"]</span>
        </div>
    </div>
    <div class="subs-panel">
        <SubstituteBench Lineup="PeriodLineups[activePeriod.Id]"
                         DraggedPlayerId="Drag.PlayerId"
                         OnSubRemoved="(pp) => RemoveSub(activePeriod.Id, pp)"
                         OnPlayerDroppedToSub="() => OnPlayerDroppedToSub(activePeriod.Id)"
                         OnSubDragStart="(playerId) => OnSubDragStart(playerId)"
                         OnSwapWithSub="(subPlayerId) => OnSwapFieldPlayerWithSub(activePeriod.Id, subPlayerId)" />
    </div>
</div>

<div class="d-flex gap-2 mt-2 mb-4">
    <MudButton Variant="Variant.Filled" Class="btn-gold" StartIcon="@Icons.Material.Filled.Save"
               OnClick="SaveAll" Size="Size.Small">
        @L["Save"]
    </MudButton>

    <MudSpacer />

    @if (!IsLastPeriodSelected)
    {
        <MudButton Variant="Variant.Outlined" Class="btn-ghost"
                   StartIcon="@Icons.Material.Filled.ContentCopy"
                   OnClick="CopyToNextPeriod" Size="Size.Small">
            @L["Copy"]
        </MudButton>
    }
</div>

@if (AllPlayers.Count > 0)
{
    <MudPaper Class="pa-5 mb-4" Elevation="2" Style="border-radius: 16px;">
        <div class="card-label">@L["Playing Time Overview"]</div>
        <MudText Typo="Typo.caption" Style="color: color-mix(in srgb, var(--ink) 40%, transparent);" Class="mb-3">
            @GameData.GameDurationMinutes min @L["Total"].ToString().ToLower() — @GameData.PeriodCount x @GameData.PeriodDurationMinutes min @L["per"] @L[GameData.SplitType.PeriodLabel()]
        </MudText>
        <MudTable Items="GetPlayingTimeData()" Dense="true" Hover="true"
                  SortLabel="@L["Sort By"]" Elevation="0" Class="playtime-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PlayingTimeRow, object>(r => r.ShirtNumber ?? 99)">
                    #</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PlayingTimeRow, object>(r => r.PlayerName)">
                    @L["Player"]</MudTableSortLabel></MudTh>
                @foreach (var period in GameData.Periods.OrderBy(p => p.PeriodType))
                {
                    <MudTh Style="text-align:center">@L[period.PeriodType.DisplayName()]</MudTh>
                }
                <MudTh Style="text-align:center">
                    <MudTableSortLabel InitialDirection="SortDirection.Descending"
                                       SortBy="new Func<PlayingTimeRow, object>(r => r.TotalMinutes)">
                        @L["Total"]</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:center; min-width:140px">
                    <MudTableSortLabel SortBy="new Func<PlayingTimeRow, object>(r => r.Percentage)">
                        %</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="#" Class="pt-num">
                    <span style="font-weight: 700; color: var(--club-primary-bright);">@(context.ShirtNumber?.ToString() ?? "-")</span>
                </MudTd>
                <MudTd DataLabel="@L["Player"]" Class="pt-name">
                    <span style="font-weight: 500; color: var(--ink);">@context.PlayerName</span>
                </MudTd>
                @foreach (var period in GameData.Periods.OrderBy(p => p.PeriodType))
                {
                    var detail = context.PeriodDetails[period.Id];
                    <MudTd Class="pt-period" Style="text-align:center">
                        @if (detail.Status == PeriodPlayStatus.Starting && detail.Fit.HasValue)
                        {
                            <span class="overview-dot @GetFitCssClass(detail.Fit.Value)"
                                  title="@detail.Position?.ToString()">
                                @detail.Position?.ToString()
                            </span>
                        }
                        else if (detail.Status == PeriodPlayStatus.Substitute)
                        {
                            <span class="overview-dot overview-sub" title="@L["Sub"]: @detail.Position?.ToString()">
                                @L["Sub"].ToString().ToUpper()
                            </span>
                        }
                        else
                        {
                            <span class="overview-dot overview-none">—</span>
                        }
                    </MudTd>
                }
                <MudTd DataLabel="@L["Total"]" Class="pt-total" Style="text-align:center">
                    <strong style="color: var(--ink);">@context.TotalMinutes min</strong>
                </MudTd>
                <MudTd DataLabel="%" Class="pt-percent" Style="text-align:center">
                    <MudProgressLinear Value="@context.Percentage" Color="@GetTimeColor(context.Percentage)"
                                       Size="Size.Medium" Rounded="true" Style="min-width:100px">
                        <MudText Typo="Typo.caption"><b>@context.Percentage.ToString("0")%</b></MudText>
                    </MudProgressLinear>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}
