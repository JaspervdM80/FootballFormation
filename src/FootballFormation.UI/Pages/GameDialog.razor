@inject IStringLocalizer<Strings> L

<MudDialog>
    <DialogContent>
        <MudForm @ref="Form">
            <MudTextField @bind-Value="Opponent" Label="@L["Opponent"]" Required="true"
                          RequiredError="@L["Opponent is required"]" Class="mb-3" />
            <MudDatePicker @bind-Date="Date" Label="@L["Date"]" Class="mb-3" />
            <MudSelect T="bool" @bind-Value="IsHomeGame" Label="@L["Venue"]" Class="mb-3">
                <MudSelectItem Value="true">@L["Home"]</MudSelectItem>
                <MudSelectItem Value="false">@L["Away"]</MudSelectItem>
            </MudSelect>
            <MudSelect T="FormationType" @bind-Value="SelectedFormationType" Label="@L["Formation"]" Class="mb-3">
                @foreach (var f in Enum.GetValues<FormationType>())
                {
                    <MudSelectItem Value="f">@f.DisplayName()</MudSelectItem>
                }
            </MudSelect>
            <MudNumericField T="int" @bind-Value="GameDurationMinutes"
                             Label="@L["Game Duration (minutes)"]" Min="10" Max="120" Step="5"
                             Class="mb-3" />
            <MudSelect T="GameSplitType" @bind-Value="SplitType" Label="@L["Game Split"]" Class="mb-3">
                <MudSelectItem Value="GameSplitType.Halves">@L["Halves (2 periods)"]</MudSelectItem>
                <MudSelectItem Value="GameSplitType.Quarters">@L["Quarters (4 periods)"]</MudSelectItem>
            </MudSelect>
            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mb-3">
                @{
                    var periods = SplitType == GameSplitType.Halves ? 2 : 4;
                    var periodLength = GameDurationMinutes / periods;
                }
                @periods x @periodLength min @L["per"] @L[SplitType.PeriodLabel()]
            </MudText>
            <MudSelect T="int" Label="@L["Unavailable Players"]" MultiSelection="true"
                       @bind-SelectedValues="UnavailablePlayerIds"
                       MultiSelectionTextFunc="@(ids => L["{0} player(s) unavailable", ids.Count()])"
                       Class="mb-3">
                @foreach (var player in SquadPlayers)
                {
                    <MudSelectItem T="int" Value="player.Id">
                        @(player.ShirtNumber is not null ? $"#{player.ShirtNumber} " : "")@player.DisplayName
                    </MudSelectItem>
                }
            </MudSelect>
            @if (GuestPlayers.Count > 0)
            {
                <MudSelect T="int" Label="@L["Guest Players"]" MultiSelection="true"
                           @bind-SelectedValues="GuestPlayerIds"
                           MultiSelectionTextFunc="@(ids => L["{0} guest(s) added", ids.Count()])"
                           Class="mb-3">
                    @foreach (var player in GuestPlayers)
                    {
                        <MudSelectItem T="int" Value="player.Id">
                            @(player.ShirtNumber is not null ? $"#{player.ShirtNumber} " : "")@player.DisplayName
                        </MudSelectItem>
                    }
                </MudSelect>
            }
            <MudTextField @bind-Value="Notes" Label="@L["Notes"]" Lines="3" Class="mb-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>
