@page "/games/{GameId:int}/result"

<PageTitle>@L["Match Result"]</PageTitle>

@if (GameData is null || AllPlayers is null)
{
    <MudProgressCircular Indeterminate="true" />
    return;
}

<div class="d-flex align-center gap-2 mb-2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack" Size="Size.Small"
                   Style="color: color-mix(in srgb, var(--ink) 40%, transparent);" />
    <div>
        <MudText Typo="Typo.h5" Style="color: var(--ink); font-weight: 700;">
            @(GameData.IsHomeGame ? "vs" : "@") @GameData.Opponent
        </MudText>
        <MudText Typo="Typo.body2" Style="color: color-mix(in srgb, var(--ink) 45%, transparent);">
            @GameData.Date.ToString("dd MMMM yyyy") · @(GameData.IsHomeGame ? L["Home"] : L["Away"]) · @GameData.FormationType.DisplayName()
        </MudText>
    </div>
</div>

<div class="result-layout">
    <MudPaper Class="pa-5" Elevation="2" Style="border-radius: 16px;">
        <div class="card-label">@L["Final Score"]</div>
        @{
            // ScoreHome/ScoreAway always mean "us"/"them"; only the display order follows the venue.
            RenderFragment ourSide =
                @<div class="score-side">
                    <span class="score-name">@L["Us"]</span>
                    <AuthorizeView Context="auth">
                        <Authorized>
                            <input type="number" class="score-big-input" min="0" max="99"
                                   value="@ScoreHome"
                                   @onchange="e => ScoreHome = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!)" />
                        </Authorized>
                        <NotAuthorized>
                            <span class="score-big-input" style="pointer-events: none;">@(ScoreHome?.ToString() ?? "–")</span>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>;
            RenderFragment opponentSide =
                @<div class="score-side">
                    <span class="score-name">@GameData.Opponent</span>
                    <AuthorizeView Context="auth">
                        <Authorized>
                            <input type="number" class="score-big-input score-away" min="0" max="99"
                                   value="@ScoreAway"
                                   @onchange="e => ScoreAway = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!)" />
                        </Authorized>
                        <NotAuthorized>
                            <span class="score-big-input score-away" style="pointer-events: none;">@(ScoreAway?.ToString() ?? "–")</span>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>;
        }
        <div class="score-visual">
            @(GameData.IsHomeGame ? ourSide : opponentSide)
            <span class="score-vs">–</span>
            @(GameData.IsHomeGame ? opponentSide : ourSide)
        </div>
        <AuthorizeView>
            <MudButton Variant="Variant.Filled" Class="btn-gold mt-4" FullWidth="true"
                       OnClick="SaveScore">
                @L["Save Score"]
            </MudButton>
        </AuthorizeView>
    </MudPaper>

    <MudPaper Class="pa-5" Elevation="2" Style="border-radius: 16px;">
        <div class="card-label">@L["Goals"] (@GameData.Goals.Count)</div>

        @if (GameData.Goals.Count > 0)
        {
            <div class="goal-timeline">
                @foreach (var goal in GameData.Goals.OrderBy(g => g.Minute))
                {
                    <div class="goal-entry @(goal.IsOwnGoal ? "own-goal" : "")">
                        <span class="goal-time">
                            @(goal.Minute.HasValue ? $"{goal.Minute}'" : "—")
                        </span>
                        <div class="goal-info">
                            <div class="goal-player">
                                @goal.Scorer.DisplayName
                                @if (goal.IsOwnGoal)
                                {
                                    <span class="own-goal-tag">(@L["OG"])</span>
                                }
                            </div>
                            @if (goal.Assister is not null)
                            {
                                <div class="goal-assist">↳ @goal.Assister.DisplayName</div>
                            }
                        </div>
                        <AuthorizeView>
                            <button class="goal-remove" @onclick="() => RemoveGoal(goal)">×</button>
                        </AuthorizeView>
                    </div>
                }
            </div>
        }
        else
        {
            <MudText Typo="Typo.body2" Style="color: color-mix(in srgb, var(--ink) 35%, transparent);" Class="mb-3">
                @L["No goals recorded yet"]
            </MudText>
        }

        <AuthorizeView>
            <div class="add-section">
                <div class="add-row">
                    <div class="field" style="width: 60px;">
                        <label>@L["Min"]</label>
                        <input type="number" min="1" max="@GameData.GameDurationMinutes"
                               value="@NewGoalMinute"
                               @onchange="e => NewGoalMinute = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!)" />
                    </div>
                    <div class="field" style="flex: 1; min-width: 110px;">
                        <label>@L["Scorer"]</label>
                        <select value="@(NewGoalScorerId?.ToString() ?? "")"
                                @onchange="e => NewGoalScorerId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!)">
                            <option value="">@L["Select player..."]</option>
                            @foreach (var player in SquadPlayers)
                            {
                                <option value="@player.Id">
                                    @(player.ShirtNumber.HasValue ? $"#{player.ShirtNumber} " : "")@player.DisplayName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="field" style="flex: 1; min-width: 110px;">
                        <label>@L["Assist"]</label>
                        <select value="@(NewGoalAssisterId?.ToString() ?? "")"
                                @onchange="e => NewGoalAssisterId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!)">
                            <option value="">@L["Optional"]</option>
                            @foreach (var player in SquadPlayers.Where(p => p.Id != NewGoalScorerId))
                            {
                                <option value="@player.Id">
                                    @(player.ShirtNumber.HasValue ? $"#{player.ShirtNumber} " : "")@player.DisplayName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="field og-check">
                        <label>@L["OG"]</label>
                        <input type="checkbox" @bind="NewGoalIsOwnGoal" />
                    </div>
                    <button class="btn-add-goal" disabled="@(NewGoalScorerId is null)" @onclick="AddGoal">
                        + @L["Add"]
                    </button>
                </div>
            </div>
        </AuthorizeView>
    </MudPaper>
</div>
