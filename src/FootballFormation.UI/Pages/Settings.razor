@page "/settings"
@attribute [Authorize]

<PageTitle>@L["Match Preferences"]</PageTitle>

<MudText Typo="Typo.h4" Style="color: var(--ink); font-weight: 700;" GutterBottom="true">
    @L["Match Preferences"]
</MudText>
<MudText Typo="Typo.body2" Style="color: color-mix(in srgb, var(--ink) 45%, transparent);" Class="mb-6">
    @L["These defaults are applied when creating new games."]
</MudText>

@if (_prefs is null)
{
    <MudProgressCircular Indeterminate="true" />
    return;
}

<MudPaper Class="pa-6" MaxWidth="500px" Elevation="2" Style="border-radius: 16px;">
    <div class="card-label">@L["Defaults"]</div>
    <MudForm @ref="_form">
        <MudNumericField T="int" @bind-Value="_prefs.GameDurationMinutes"
                         Label="@L["Game Duration (minutes)"]" Min="10" Max="120" Step="5"
                         Class="mb-4" />

        <MudSelect T="GameSplitType" @bind-Value="_prefs.DefaultSplitType"
                   Label="@L["Default Game Split"]" Class="mb-4">
            <MudSelectItem Value="GameSplitType.Halves">@L["Halves (2 periods)"]</MudSelectItem>
            <MudSelectItem Value="GameSplitType.Quarters">@L["Quarters (4 periods)"]</MudSelectItem>
        </MudSelect>

        <MudSelect T="FormationType" @bind-Value="_prefs.DefaultFormation"
                   Label="@L["Default Formation"]" Class="mb-4">
            @foreach (var f in Enum.GetValues<FormationType>())
            {
                <MudSelectItem Value="f">@f.DisplayName()</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="DayOfWeek" @bind-Value="_prefs.MatchDay"
                   Label="@L["Match Day"]" Class="mb-4">
            @foreach (var day in Enum.GetValues<DayOfWeek>())
            {
                <MudSelectItem Value="day">@System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.GetDayName(day)</MudSelectItem>
            }
        </MudSelect>

        <MudText Typo="Typo.caption" Style="color: color-mix(in srgb, var(--ink) 45%, transparent);" Class="mb-4">
            @L["Next calculated match date:"] <strong style="color: var(--club-primary-bright);">@_nextMatchDate?.ToString("dddd dd MMM yyyy")</strong>
        </MudText>
    </MudForm>

    <MudButton Variant="Variant.Filled" Class="btn-gold" StartIcon="@Icons.Material.Filled.Save"
               OnClick="Save" FullWidth="true">
        @L["Save Preferences"]
    </MudButton>
</MudPaper>

<MudPaper Class="pa-6 mt-6" MaxWidth="500px" Elevation="2" Style="border-radius: 16px;">
    <div class="card-label">@L["Change Password"]</div>
    <MudForm @ref="_passwordForm">
        <MudTextField T="string" @bind-Value="_currentPassword" Label="@L["Current Password"]"
                      InputType="InputType.Password" Required="true" Class="mb-4" />
        <MudTextField T="string" @bind-Value="_newPassword" Label="@L["New Password"]"
                      InputType="InputType.Password" Required="true" Class="mb-4" />
        <MudTextField T="string" @bind-Value="_confirmPassword" Label="@L["Confirm New Password"]"
                      InputType="InputType.Password" Required="true" Class="mb-4" />
    </MudForm>

    <MudButton Variant="Variant.Filled" Class="btn-gold" StartIcon="@Icons.Material.Filled.Lock"
               OnClick="ChangePassword" FullWidth="true">
        @L["Change Password"]
    </MudButton>
</MudPaper>
