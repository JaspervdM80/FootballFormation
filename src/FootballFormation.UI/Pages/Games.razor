@page "/games"

<PageTitle>@L["Games"]</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="color: var(--ink); font-weight: 700;">@L["Games"]</MudText>
        <MudText Typo="Typo.body2" Style="color: color-mix(in srgb, var(--ink) 45%, transparent);">
            @if (_games is not null)
            {
                @(_games.Count == 1 ? L["{0} match", _games.Count] : L["{0} matches", _games.Count])
            }
        </MudText>
    </div>
    <AuthorizeView>
        <MudButton Variant="Variant.Filled" Class="btn-gold" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialog">
            @L["Add"]
        </MudButton>
    </AuthorizeView>
</div>

@if (_games is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_games.Count == 0)
{
    <MudPaper Class="pa-6" Elevation="2" Style="border-radius: 16px; text-align: center;">
        <MudIcon Icon="@Icons.Material.Filled.SportsSoccer" Size="Size.Large" Style="color: color-mix(in srgb, var(--ink) 25%, transparent);" />
        <MudText Typo="Typo.body1" Class="mt-3" Style="color: color-mix(in srgb, var(--ink) 50%, transparent);">
            @L["No games yet. Create your first game!"]
        </MudText>
    </MudPaper>
}
else
{
    <div class="game-cards">
        @foreach (var game in _games.OrderByDescending(g => g.Date))
        {
            <div class="game-row" @onclick="() => OpenGame(game)">
                <div class="game-primary">
                    <span class="game-date">@game.Date.ToString("dd MMM")</span>
                    <span class="game-opponent">@(game.IsHomeGame ? "vs" : "@") @game.Opponent</span>
                </div>
                <span class="badge-venue">@(game.IsHomeGame ? L["H"] : L["A"])</span>
                <span class="badge-gold">@game.FormationType.DisplayName()</span>
                @if (game.UnavailablePlayerIds.Count > 0)
                {
                    <span class="badge-unavailable">@L["{0} out", game.UnavailablePlayerIds.Count]</span>
                }
                @if (game.GuestPlayerIds.Count > 0)
                {
                    <span class="badge-guest">@L["+{0} guest", game.GuestPlayerIds.Count]</span>
                }
                @if (game.ScoreHome.HasValue && game.ScoreAway.HasValue)
                {
                    var scoreClass = game.ScoreHome > game.ScoreAway ? "win" : game.ScoreHome < game.ScoreAway ? "loss" : "draw";
                    @* Scoreboard reads in venue order: the home side is listed first. *@
                    var left = game.IsHomeGame ? game.ScoreHome : game.ScoreAway;
                    var right = game.IsHomeGame ? game.ScoreAway : game.ScoreHome;
                    <span class="game-score @scoreClass">@left – @right</span>
                }
                <div class="game-actions" @onclick:stopPropagation="true">
                    <AuthorizeView>
                        <button class="action-btn" title="@L["Formation"]" @onclick="() => OpenFormation(game.Id)">
                            <MudIcon Icon="@Icons.Material.Filled.ViewModule" Size="Size.Small" />
                        </button>
                    </AuthorizeView>
                    <button class="action-btn" title="@L["Overview"]" @onclick="() => OpenOverview(game.Id)">
                        <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" />
                    </button>
                    <button class="action-btn" title="@L["Result"]" @onclick="() => OpenResult(game.Id)">
                        <MudIcon Icon="@Icons.Material.Filled.Scoreboard" Size="Size.Small" />
                    </button>
                    <AuthorizeView>
                        <button class="action-btn" title="@L["Edit"]" @onclick="() => OpenEditDialog(game)">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        </button>
                        <button class="action-btn action-delete" title="@L["Delete"]" @onclick="() => DeleteGame(game)">
                            <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                        </button>
                    </AuthorizeView>
                </div>
            </div>
        }
    </div>
}
