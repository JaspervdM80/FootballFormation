@page "/players"

<PageTitle>@L["Players"]</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="color: white; font-weight: 700;">@L["Squad"]</MudText>
        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.35);">
            @if (_players is not null)
            {
                var squadCount = _players.Count(p => !p.IsGuest);
                var guestCount = _players.Count - squadCount;
                @(squadCount == 1 ? L["{0} player", squadCount] : L["{0} players", squadCount])
                @(guestCount > 0 ? " · " + (guestCount == 1 ? L["{0} guest", guestCount] : L["{0} guests", guestCount]) : "")
            }
        </MudText>
    </div>
    <AuthorizeView>
        <MudButton Variant="Variant.Filled" Class="btn-gold" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenAddDialog">
            @L["Add Player"]
        </MudButton>
    </AuthorizeView>
</div>

@if (_players is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_players.Count == 0)
{
    <MudPaper Class="pa-6" Elevation="2" Style="border-radius: 16px; text-align: center;">
        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Style="color: rgba(255,255,255,0.15);" />
        <MudText Typo="Typo.body1" Class="mt-3" Style="color: rgba(255,255,255,0.4);">
            @L["No players yet. Add your first player!"]
        </MudText>
    </MudPaper>
}
else
{
    <MudTable Items="_players" Hover="true" Dense="true" Elevation="2"
              Class="players-table" Style="border-radius: 16px;">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<Player, object>(p => p.ShirtNumber ?? 999)">#</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Player, object>(p => p.FirstName)">@L["Name"]</MudTableSortLabel></MudTh>
            <AuthorizeView Context="authHeader">
                <MudTh>@L["Preferred Position"]</MudTh>
                <MudTh Class="cell-right">@L["Alternative Positions"]</MudTh>
                <MudTh Class="cell-right"></MudTh>
            </AuthorizeView>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="#">
                <span style="font-weight: 700; color: #fbbf24;">@context.ShirtNumber</span>
            </MudTd>
            <MudTd DataLabel="@L["Name"]">
                @* One wrapper so the mobile card's flex row treats number + name as a
                   single item; otherwise space-between pushes them to opposite ends. *@
                <span class="player-name-cell">
                    @* Mobile only: the # column is hidden there, so the number rides along here *@
                    @if (context.ShirtNumber is not null)
                    {
                        <span class="shirt-inline">#@context.ShirtNumber</span>
                    }
                    <span style="font-weight: 600; color: white;">@context.DisplayName</span>
                    @if (context.IsGuest)
                    {
                        <span class="badge-guest" style="margin-left: 6px;">@L["GUEST"]</span>
                    }
                </span>
            </MudTd>
            <AuthorizeView Context="authRow">
                <MudTd DataLabel="@L["Preferred Position"]">
                    <span class="badge-gold">@context.PreferredPosition.ToString()</span>
                </MudTd>
                <MudTd DataLabel="@L["Alternative Positions"]" Class="cell-right">
                    @foreach (var pos in context.AlternativePositions)
                    {
                        <span class="badge-teal" style="margin-right: 4px;">@pos.ToString()</span>
                    }
                </MudTd>
                <MudTd Class="cell-right">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   Style="color: rgba(255,255,255,0.3);"
                                   OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Style="color: rgba(255,255,255,0.3);"
                                   OnClick="() => DeletePlayer(context)" />
                </MudTd>
            </AuthorizeView>
        </RowTemplate>
    </MudTable>
}
